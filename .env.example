# GitHub Personal Access Token (required)
GITHUB_PERSONAL_ACCESS_TOKEN=your_token_here

# Optional: GitHub host (default: github.com)
# For GitHub Enterprise Server: https://github.enterprise.com
# For GitHub Enterprise Cloud with data residency: https://yoursubdomain.ghe.com
# GITHUB_HOST=

# Optional: Comma-separated list of toolsets to enable
# Available: context,repos,issues,pull_requests,users
# Default: context,repos,issues,pull_requests,users
# GITHUB_TOOLSETS=context,repos,issues,pull_requests,users

# Optional: Read-only mode (1 or true to enable)
# GITHUB_READ_ONLY=false
